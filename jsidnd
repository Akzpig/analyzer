    var exportContent: String {
        let date = Date().formatted()
        let imei = imeiText.isEmpty ? "N/A" : imeiText
        let codes = results.map { $0.code }.joined(separator: ", ")
        let part = results.first?.suggestedPart ?? "Component"
        
        if isHebrew {
            return """
            --- דור הסלולר - דוח מעבדה ---
            תאריך: \(date)
            IMEI: \(imei)
            
            סיכום אבחון:
            זוהתה תקלה בחומרה: \(codes)
            תיאור: \(results.first?.hebrewDesc ?? "")
            
            סטטוס תיקון:
            הרכיב הפגום (\(part)) הוחלף בחדש. המכשיר עבר בדיקה מקיפה לאחר התיקון ונמצא תקין לחלוטין. כל הפונקציות חזרו לפעילות מלאה.
            ---------------------------
            """
        } else {
            return """
            --- Dor Cellular - Diagnostic Report ---
            Date: \(date)
            IMEI: \(imei)
            
            Diagnostic Summary:
            Hardware failure detected: \(codes)
            Description: \(results.first?.englishDesc ?? "")
            
            Repair Status:
            The faulty component (\(part)) has been replaced. The device has undergone a full post-repair diagnostic and is now fully functional. All systems are operating normally.
            ---------------------------------------
            """
        }
    }

    func processScannedImage(_ image: UIImage) {
        guard let cgImage = image.cgImage else { return }
        let request = VNRecognizeTextRequest { request, _ in
            guard let observations = request.results as? [VNRecognizedTextObservation] else { return }
            let fullText = observations.compactMap { $0.topCandidates(1).first?.string }.joined(separator: " ")
            
            DispatchQueue.main.async {
                if let imeiRange = fullText.range(of: #"\b\d{15}\b"#, options: .regularExpression) {
                    self.imeiText = String(fullText[imeiRange])
                }
                // Scans for 'panic(', 'sensor:', or 'AOP' strings
                if let panicRange = fullText.range(of: #"(panic\(|sensor: |aop|missing sensor).*?"#, options: [.regularExpression, .caseInsensitive]) {
                    self.logText = String(fullText[panicRange])
                } else {
                    self.logText = String(fullText.prefix(400))
                }
            }
        }
        request.recognitionLevel = .accurate
        try? VNImageRequestHandler(cgImage: cgImage, options: [:]).perform([request])
    }

    func analyzeLog() {
        let found = knowledgeBase.filter { logText.lowercased().contains($0.code.lowercased()) }
        if found.isEmpty {
            results = [PanicError(code: "Unknown", englishDesc: "No specific sensor code detected. Try scanning the 'Sensor' line or scrolling lower in the log.", hebrewDesc: "לא זוהה קוד חיישן ספציפי. נסה לסרוק את שורת ה-Sensor או לגלול מטה בלוג.", suggestedPart: "Further Diagnostics")]
        } else {
            results = found
            for error in results {
                history.insert(PanicRecord(date: Date(), errorCode: error.code, imei: imeiText, description: error.englishDesc), at: 0)
            }
        }
    }
    
    func resetAll() {
        logText = ""; imeiText = ""; results = []
    }
}
